{
  "name": "metamorphic-mixtape",
  "version": "1.0.0",
  "description": "Skeptical Wombat's Metamorphic Mixtape - AI-powered MCP server for Suno songwriting workflows",
  "main": "dist/index.js",
  "type": "module",
  "workspaces": ["web"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "start:http": "node dist/http/index.js",
    "build:web": "npm run build --workspace web",
    "test:contracts": "node dist/scripts/validate-contracts.js"
  },
  "keywords": [
    "mcp",
    "suno",
    "songwriting",
    "ai",
    "music"
  ],
  "author": "Suno MCP Developer",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  }
}